# Copy file ini jadi `keystore.properties` (yang asli di-gitignore) untuk signing
# release secara lokal. JANGAN commit keystore.properties atau file .keystore-nya!
#
#   cp keystore.properties.example keystore.properties
#
# storeFile di-resolve relatif ke root project (letakkan release.keystore di root repo).
storeFile=release.keystore
storePassword=YOUR_STORE_PASSWORD
keyAlias=agallery
keyPassword=YOUR_KEY_PASSWORD
