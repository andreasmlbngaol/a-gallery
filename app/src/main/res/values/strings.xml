    <string name="style_solid">Solid</string>
    <string name="style_frosted">Frosted</string>
    <string name="style_glass">Glass</string>

    <string name="perf_desc_low">Lightest on RAM, CPU &amp; GPU. Thumbnails load only as you reach them, so scrolling stays cheap on low-end devices — images may pop in slightly later.</string>
    <string name="perf_desc_balanced">Balanced RAM, CPU &amp; GPU use. Preloads a few rows ahead for smooth scrolling without decoding too much in the background.</string>
    <string name="perf_desc_high">Uses more RAM (bigger cache) plus more CPU &amp; GPU to decode many rows ahead (and above) so scrolling rarely waits. Best on powerful devices; cache size changes apply after restart.</string>
    <string name="style_desc_solid">Solid semi-transparent bars. Lightest — no blur, smoothest on any device.</string>
    <string name="style_desc_frosted">Frosted translucent glass. Smooth and still glassy — recommended for most devices.</string>
    <string name="style_desc_glass">Live liquid glass that refracts the photo behind it. Looks best but is the HEAVIEST: it drives the GPU every frame and can cause lag on some devices.</string>
    <string name="style_desc_glass_unsupported">Needs Android 13+ — falls back to Frosted on this device.</string>
    <string name="edge_desc_blurry">Blurred glass behind the system bars.</string>
    <string name="edge_desc_blurry_unsupported">Needs Android 12+ — falls back to Darken on this device.</string>
    <string name="edge_desc_darken">Subtle dark gradient, light on every device.</string>
    <string name="edge_desc_off">No effect at the screen edges.</string>

