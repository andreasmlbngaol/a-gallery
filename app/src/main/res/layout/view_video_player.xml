<?xml version="1.0" encoding="utf-8"?>
<!--
  PlayerView untuk viewer video.
  surface_type=texture_view : frame video ikut ter-render di view hierarchy
    sehingga bisa di-capture Kyant layerBackdrop (dibiaskan panel liquid glass).
    SurfaceView (default) = hardware layer terpisah, nggak ke-capture.
  use_controller=false     : kontrol pakai UI Compose custom, bukan bawaan.
  resize_mode=fit          : jaga aspect ratio video (tidak stretch).
-->
<androidx.media3.ui.PlayerView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    app:surface_type="texture_view"
    app:use_controller="false"
    app:resize_mode="fit" />
